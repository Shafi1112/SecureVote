NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/securevote
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# Gmail SMTP. Use a Google App Password, not your Gmail login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-google-app-password
MAIL_FROM="SecureVote <your-gmail@gmail.com>"

ADMIN_NAME=SecureVote Admin
ADMIN_EMAIL=admin@securevote.local
ADMIN_PASSWORD=ChangeMe123!
